# bedvibe-vad configuration — copy this file to ".env" and adjust.
# Every value is optional; the defaults below match the original setup.

# ASR / Whisper inference endpoint that receives each WAV segment.
VAD_WHISPER_URL=http://127.0.0.1:8000/inference

# TCP port this tool CONNECTS to, to deliver transcriptions (host app listens here).
VAD_UNITY_PORT=5005

# TCP port this tool LISTENS on for "start" / "mute" commands from the host.
VAD_MUTE_PORT=5006

# Voice-activity threshold in dB (higher = less sensitive).
VAD_THRESHOLD_DB=-30.0

# Silence duration in ms before a speech segment is finalized and sent.
VAD_SILENCE_MS=1200
